root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,fs,fsx,fsi,json,yaml,yml,md,txt,xml,toml,ini,cfg}]
indent_size = 4

[*.{h,cpp,hpp,c,glsl,hlsl,usf,ush}]
indent_size = 4

[*.{sh,bat,cmd,ps1,psm1,psd1}]
indent_size = 4

[*.{py}]
indent_size = 4

[*.{js,ts,jsx,tsx}]
indent_size = 2

[*.{html,css,scss,sass}]
indent_size = 2

# UE5 specific
[*.{Build.cs,Target.cs,Module.cs}]
indent_size = 4

# F# specific
[*.{fs,fsx,fsi}]
indent_style = space
indent_size = 4

# C# specific
[*.cs]
indent_style = space
indent_size = 4