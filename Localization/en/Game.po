#: Faction Descriptions
msgid "FactionDesc_USA"
msgstr "Advanced technology and air superiority. Precision strikes, stealth, and drone warfare."

msgid "FactionDesc_China"
msgstr "Mass production and artillery doctrine. Overwhelming numbers and area denial."

msgid "FactionDesc_GLA"
msgstr "Guerrilla tactics and subterfuge. Toxin networks, suicide units, and ambushes."

msgid "FactionDesc_Turkiye"
msgstr "Autonomous drone dominance and mobile fortresses. Bayraktar swarms and Altay tanks."

msgid "FactionDesc_Iran"
msgstr "Ballistic armor and fortress doctrine. Underground silos and long-range rocket barrages."

msgid "FactionDesc_Pakistan"
msgstr "Asymmetric counterstrike and EMP ambushes. Stealth training camps and guerrilla regeneration."

msgid "FactionDesc_India"
msgstr "Technological mass and railgun prototypes. SDRF tech center and composite reactive armor."

msgid "FactionDesc_Japan"
msgstr "Precise mecha robotics and quantum networks. Tetsujin walkers and plasma shields."

msgid "FactionDesc_SouthKorea"
msgstr "K-Cyber network and subsonic stealth air force. KF-X Black Sharks and satellite relay."

msgid "FactionDesc_Russia"
msgstr "Heavy armor industry and thermobaric devastation. T-14 Armata Overlord and Giga-Factory."

