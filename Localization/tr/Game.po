#: Faction Descriptions
msgid "FactionDesc_USA"
msgstr "İleri teknoloji ve hava üstünlüğü. Hassas isabet, gizlilik ve drone savaşçılığı."

msgid "FactionDesc_China"
msgstr "Kitle üretimi ve topçu doktrini. Baskın sayılar ve alan engelleme."

msgid "FactionDesc_GLA"
msgstr "Gerilla taktiği ve aldatmaca. Toksin ağları, intihar üniteleri ve pusu stratejileri."

msgid "FactionDesc_Turkiye"
msgstr "Otonom drone hakimiyeti ve mobil kaleler. Bayraktar sürüleri ve Altay tankları."

msgid "FactionDesc_Iran"
msgstr "Balistik zırh ve kale doktrini. Yeraltı siloları ve uzun menzilli roket fırtınaları."

msgid "FactionDesc_Pakistan"
msgstr "Asimetrik karşı saldırı ve EMP pusu. Gizli eğitim kampları ve gerilla rejenerasyonu."

msgid "FactionDesc_India"
msgstr "Teknolojik kitle ve raylı silah prototipleri. SDRF teknoloji merkezi ve kompozit reaktif zırh."

msgid "FactionDesc_Japan"
msgstr "Kesin meka robotik ve kuantum ağlar. Tetsujin yürüyenler ve plazma kalkanları."

msgid "FactionDesc_SouthKorea"
msgstr "K-Siber ağ ve alt sesli gizli hava kuvveti. KF-X Kara Köpekler ve uydu aktarımı."

msgid "FactionDesc_Russia"
msgstr "Ağır zırh sanayisi ve termobarik tahrip. T-14 Armata Overlord ve Giga-Fabrik."

